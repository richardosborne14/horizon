# ============================================================
# Communauté Coiffure V2 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Database ---
# PostgreSQL connection string (asyncpg driver)
# In Docker Compose: db hostname resolves to the db container
DATABASE_URL=postgresql+asyncpg://comcoi:yourpassword@db:5432/comcoi

# --- Security ---
# Strong random secret for session signing. Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-random-secret

# --- AI: Anthropic ---
# API key for CoCo (claude-haiku for chat, claude-sonnet for analysis)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- AI: DeepInfra (embeddings for CoCo RAG) ---
# EU-friendly, GDPR-compliant embedding API. Model: BAAI/bge-m3 (multilingual, 1024-dim)
# Get from: https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=your-deepinfra-key

# --- AI: Perplexity (web search for CoCo) ---
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# --- Bubble (legacy data import) ---
# Private API key for the Bubble production app (espacepro.communaute-coiffure.com)
# Used to import blog articles, users, salons from Bubble DB during migration
BUBBLE_API_KEY=your-bubble-private-api-key

# --- Payments: Stripe ---
# Secret key (keep server-side only)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret (from Stripe dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key (safe to expose in frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Noly Compta ---
# SSO redirect URL for Noly Compta integration
NOLY_SSO_URL=https://app.noly-compta.fr/sso

# --- Email (SMTP) ---
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=noreply@communaute-coiffure.fr
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=Communauté Coiffure <noreply@communaute-coiffure.fr>

# --- Payslip / Fiches de salaire ---
# Email where payslip form submissions are sent
PAYSLIP_NOTIFICATION_EMAIL=admin@communaute-coiffure.fr
# Price per payslip in cents (2880 = €28.80 TTC)
PAYSLIP_UNIT_PRICE_CENTS=2880

# --- App settings ---
# Environment: development | production
APP_ENV=development
# Allow CORS from this origin (frontend URL)
# Dev: http://localhost:5178 (5173-5177 taken by other projects on this dev machine)
# Production: https://app.communaute-coiffure.fr
FRONTEND_URL=http://localhost:5178

# ============================================================
# Hetzner Cloud (production infrastructure)
# Used by scripts/provision-hetzner.sh and scripts/deploy.sh
# ============================================================

# API token from: https://console.hetzner.cloud → Project → Security → API Tokens
# Create a Read+Write token. This is sensitive — never commit it.
HETZNER_API_TOKEN=your-hetzner-api-token

# IPv4 address of the production server.
# Populated automatically by provision-hetzner.sh after VM creation.
# You can also find it in the Hetzner Cloud Console after provisioning.
HETZNER_SERVER_IP=1.2.3.4

# Name of the SSH key registered in Hetzner (must match what provision-hetzner.sh uploads)
HETZNER_SSH_KEY_NAME=comcoi-deploy

# Path to the SSH private key on YOUR local machine (used by deploy.sh to SSH in)
# provision-hetzner.sh generates this key automatically.
HETZNER_SSH_KEY_PATH=~/.ssh/comcoi_hetzner

# ============================================================
# Frontend environment variables (place these in frontend/.env)
# ============================================================

# URL the SvelteKit SSR Node server uses to call the FastAPI backend.
# Local dev (backend running in Docker on host port 8002): http://localhost:8002
# Inside Docker Compose network (production): http://backend:8000
VITE_API_URL=http://localhost:8002
